{
  "name": "@at-flux/graphy-toolkit",
  "version": "1.0.2",
  "type": "module",
  "description": "CLI for still and clip release pipelines (graphy)",
  "license": "MIT",
  "author": "Taylor Siviter <taylor@siviter.xyz>",
  "bin": {
    "graphy": "./dist/bin/graphy.js"
  },
  "files": [
    "dist/bin",
    "dist/commands",
    "dist/config",
    "dist/ui",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"const fs=require('fs');const p='dist/commands/stills-run.js';if(fs.existsSync(p))fs.unlinkSync(p);\" && tsc -p tsconfig.build.json",
    "prebuild": "pnpm --filter @at-flux/graphy-toolkit-core run build",
    "graphy": "node dist/bin/graphy.js",
    "bundle": "esbuild src/bin/graphy.ts --bundle --platform=node --format=esm --outfile=dist/bundle/graphy.mjs --external:sharp --alias:@at-flux/graphy-toolkit-core=../graphy-toolkit-core/dist/index.js --banner:js=\"#!/usr/bin/env node\"",
    "bundle:deno": "esbuild src/bin/graphy.ts --bundle --platform=node --format=esm --outfile=dist/bundle/graphy-deno.mjs --packages=external --alias:@at-flux/graphy-toolkit-core=../graphy-toolkit-core/dist/index.js",
    "dev": "tsx src/bin/graphy.ts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@at-flux/graphy-toolkit-core": "workspace:*",
    "@stricli/core": "1.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "esbuild": "0.28.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/at-flux/graphy-toolkit.git",
    "directory": "packages/graphy-toolkit"
  }
}
