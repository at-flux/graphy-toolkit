{
  "name": "@at-flux/graphy-toolkit-core",
  "version": "1.0.1",
  "type": "module",
  "description": "Image and clip pipeline engine for graphy (Sharp, Zod, preset-driven steps)",
  "license": "MIT",
  "author": "Taylor Siviter <taylor@siviter.xyz>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "fast-glob": "3.3.3",
    "sharp": "0.34.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/at-flux/graphy-toolkit.git",
    "directory": "packages/graphy-toolkit-core"
  }
}
