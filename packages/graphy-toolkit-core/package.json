{
  "name": "@at-flux/graphy-toolkit-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Image and clip pipeline engine for graphy (Sharp, Zod, preset-driven steps)",
  "license": "MIT",
  "author": "Taylor Siviter <taylor@siviter.xyz>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "fast-glob": "3.3.3",
    "sharp": "0.34.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/at-flux/graphy-toolkit.git",
    "directory": "packages/graphy-toolkit-core"
  }
}
