{
  "name": "@at-flux/graphy-toolkit-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "graphy": "node packages/graphy-toolkit/dist/bin/graphy.js",
    "test:fixtures": "pnpm build && cd ../test && rm -rf dist && node ../graphy-toolkit/packages/graphy-toolkit/dist/bin/graphy.js stills && cd ../graphy-toolkit/packages/graphy-toolkit-core && node ../../scripts/verify-test-dist.mjs",
    "test:pack": "bash scripts/test-pack-local.sh",
    "ci": "bash scripts/ci.sh",
    "release": "multi-semantic-release",
    "compile:graphy": "bash scripts/compile-graphy.sh"
  },
  "devDependencies": {
    "@qiwi/multi-semantic-release": "^7.1.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/release-notes-generator": "14.1.1",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3"
  }
}
