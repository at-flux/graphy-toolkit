{
  "name": "@at-flux/graphy-toolkit-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=20.18",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "graphy": "node packages/graphy-toolkit/dist/bin/graphy.js",
    "test:fixtures": "pnpm build && cd ../test && rm -rf dist && node ../graphy-toolkit/packages/graphy-toolkit/dist/bin/graphy.js stills && cd ../graphy-toolkit/packages/graphy-toolkit-core && node ../../scripts/verify-test-dist.mjs",
    "test:pack": "bash scripts/test-pack-local.sh",
    "release": "multi-semantic-release",
    "compile:graphy": "bash scripts/compile-graphy-local.sh",
    "compile:graphy:docker": "docker compose -f docker/compose.yml run --rm compile",
    "dev:shell": "docker compose -f docker/compose.yml run --rm dev"
  },
  "devDependencies": {
    "@qiwi/multi-semantic-release": "^7.1.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "prettier": "^3.2.5",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
