{
  "name": "@at-flux/graphy-toolkit-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint && eslint scripts",
    "lint:fix": "pnpm -r lint:fix && eslint scripts --fix",
    "format": "prettier --write '**/*.{ts,js,mjs,json,md}' --ignore-unknown",
    "format:check": "prettier --check '**/*.{ts,js,mjs,json,md}' --ignore-unknown",
    "typecheck": "pnpm -r typecheck",
    "graphy": "node packages/graphy-toolkit/dist/bin/graphy.js",
    "test:fixtures": "pnpm build && cd ../test && rm -rf dist && node ../graphy-toolkit/packages/graphy-toolkit/dist/bin/graphy.js stills && cd ../graphy-toolkit/packages/graphy-toolkit-core && node ../../scripts/verify-test-dist.mjs",
    "test:pack": "bash scripts/test-pack-local.sh",
    "ci": "bash scripts/ci.sh",
    "release": "multi-semantic-release",
    "compile:graphy": "bash scripts/compile-graphy.sh"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@qiwi/multi-semantic-release": "^7.1.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/release-notes-generator": "14.1.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "globals": "16.4.0",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "typescript-eslint": "8.57.2",
    "typescript": "6.0.3"
  }
}
